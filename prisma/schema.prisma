// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  phone         String?
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user", "admin", "supersu"
  accounts      Account[]
  sessions      Session[]
  watchlist     WatchlistItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WatchlistItem {
  id              String   @id @default(cuid())
  userId          String
  showId          Int
  showName        String
  showImage       String?
  showRating      Float?
  showGenres      String?  // Stored as JSON or comma-separated
  trackerStatus     String   // "watching", "completed", "plantowatch", "dropped"
  personalRating    Int?
  personalNotes     String?
  watchedEpisodeIds String?  // Stored as JSON array of numbers
  totalEpisodes     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, showId]) // A user can only have one entry per show
}
